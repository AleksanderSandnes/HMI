{
  "name": "hmi-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "web": "npm --workspace @hmi/web run dev",
    "mobile": "npm --workspace @hmi/mobile run start"
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "turbo": "^2.3.3",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "js-yaml": "^4.2.0",
    "uuid": "^11.1.1",
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.9"
    }
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "npm@11.16.0"
}
