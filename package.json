{
  "name": "hmi",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "start:dev": "cross-env EXPO_PUBLIC_DATA_MODE=development expo start",
    "web:dev": "cross-env EXPO_PUBLIC_DATA_MODE=development expo start --web",
    "android:dev": "cross-env EXPO_PUBLIC_DATA_MODE=development expo start --android",
    "ios:dev": "cross-env EXPO_PUBLIC_DATA_MODE=development expo start --ios",
    "start:prod": "cross-env EXPO_PUBLIC_DATA_MODE=production expo start",
    "web:prod": "cross-env EXPO_PUBLIC_DATA_MODE=production expo start --web",
    "android:prod": "cross-env EXPO_PUBLIC_DATA_MODE=production expo start --android",
    "ios:prod": "cross-env EXPO_PUBLIC_DATA_MODE=production expo start --ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint app src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "npm run lint -- --fix"
  },
  "dependencies": {
