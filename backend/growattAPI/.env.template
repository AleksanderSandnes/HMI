# Environment Template for Growatt API
# Copy this file to .env (which is gitignored) and fill in your actual values

# ==============================================
# GROWATT API CREDENTIALS
# ==============================================
GROWATT_ACCOUNT=your-growatt-account@domain.com
GROWATT_PASSWORD=your-secure-password

# ==============================================
# PROXY CONFIGURATION (if needed)
# ==============================================
PROXY_URL=
PROXY_PORT=

# ==============================================
# APPLICATION CONFIGURATION
# ==============================================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=production

# ==============================================
# SECURITY CONFIGURATION
# ==============================================
# Set to true in production for HTTPS
SERVER_SERVLET_SESSION_COOKIE_SECURE=true

# ==============================================
# LOGGING CONFIGURATION
# ==============================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_CONTROLLER=INFO

# ==============================================
# MANAGEMENT/ACTUATOR CONFIGURATION
# ==============================================
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=never

# ==============================================
# NOTES FOR PRODUCTION DEPLOYMENT
# ==============================================
# 1. Never commit the actual .env file to git
# 2. Use environment variables in production (Docker, Kubernetes, etc.)
# 3. Consider using a secrets management system for production
# 4. Rotate credentials regularly
# 5. Use strong passwords and consider 2FA where possible
