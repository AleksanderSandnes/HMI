# Simple single-stage Dockerfile for Render
FROM maven:3.9.4-eclipse-temurin-17-alpine

WORKDIR /app

# Copy everything
COPY . .

# Build the application
RUN mvn clean package -DskipTests

# Expose port
# EXPOSE 8080 (Render sets the port via $PORT)

# Run the application
CMD ["java", "-jar", "target/growatt-1.0-SNAPSHOT.jar"]
