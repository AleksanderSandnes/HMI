# HMI web (apps/web) environment. Copy to .env.local and fill in.
# Build-time data mode: "development" (local dev) or "production".
NEXT_PUBLIC_DATA_MODE=development

# Supabase. For LOCAL dev run `supabase start` and use its printed values:
#   NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#   NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon key from `supabase status`>
# To use the HOSTED project instead, point these at it (URL ends in .supabase.co).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Java Growatt service base URL (no trailing /api).
# When left blank with DATA_MODE=development, the app calls http://localhost:8080,
# so the local Java service MUST be running (cd backend/growattAPI &&
# SPRING_PROFILES_ACTIVE=local mvn spring-boot:run) or Solar/Dashboard show no data.
# To use the deployed backend instead, set https://growattapi.onrender.com.
NEXT_PUBLIC_JAVA_API=
