# HMI mobile (apps/mobile) environment. Copy to .env and fill in.
# Expo loads this file from apps/mobile (the Expo project root).
# This .env is the LOCAL dev config, loaded by `expo start` / npm run *:dev.
# The npm run *:prod scripts pass `--no-dev`, which builds a production bundle that
# reads .env.production instead (this file is ignored there). That's the ONLY reliable
# way to override .env for prod: Expo force-merges .env into every dev bundle, so shell
# / cross-env vars can't win over it — a production bundle is required to switch files.
# Build-time data mode: "development" (local dev) or "production".
EXPO_PUBLIC_DATA_MODE=development

# Supabase. For LOCAL dev run `supabase start` and use its printed values.
#   Simulator / Expo web: http://127.0.0.1:54321
#   Android emulator:     http://10.0.2.2:54321
#   Physical device:      http://<your-machine-LAN-IP>:54321
# To use the HOSTED project instead, point these at it (URL ends in .supabase.co).
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Java Growatt service base URL (no trailing /api). Blank in a local dev build
# targets http://localhost:8080; an installed/store build falls back to the
# deployed service. A physical device must use your machine's LAN IP, not localhost.
EXPO_PUBLIC_JAVA_API=
