# ==============================================
# SECURITY & SENSITIVE DATA - CRITICAL TO IGNORE
# ==============================================

# Environment files (credentials) — but keep the secret-free example templates
.env*
!.env.example
!**/.env.example

# Google Play service account key (eas submit)
play-service-account.json

# Spring property files that may hold secrets. The committed application-local
# and application-production profiles use env-var overrides + Supabase Vault, so
# they are NOT matched here; the bare application.properties (e.g. the test
# resource holding real Growatt creds) and the variants below stay ignored.
**/application.properties
**/application-dev.properties
**/application-staging.properties
**/*.properties.backup
**/*.properties.bak
**/credentials.properties
**/secrets.properties
**/config.properties
**/*-credentials.properties
**/*-secrets.properties

